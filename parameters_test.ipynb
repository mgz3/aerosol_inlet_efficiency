   "source": [
    "from math import pi\n",
    "\n",
    "Q = 2 # L/min\n",
    "Q = Q / 60 # L/s\n",
    "Q = Q / 1000 # m^3/s\n"
   ],
   "outputs": [],
   "execution_count": 1
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-04-09T09:40:54.962826438Z",
     "start_time": "2026-04-09T09:40:54.889827162Z"
    }
   },
   "cell_type": "code",
   "source": [
    "d_inlet = 8 # mm\n",
    "seccion_inlet = pi * (d_inlet/2)**2 # mm^2\n",
    "\n",
    "V_inlet = Q / (seccion_inlet * 1e-6) # m/s\n",
    "print(f\"Velocidad en la entrada: {V_inlet:.2f} m/s\")"
   ],
